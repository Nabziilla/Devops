// Australian DevOps Compliance Platform - Data Model
// Maps to the framework: Privacy Act, NDB, SOCI, APRA CPS 234, Essential 8, CDR, PCI DSS, etc.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// Org & people
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  role          String   // admin, engineer, auditor, executive
  department    String?
  mfaEnabled    Boolean  @default(false)
  lastLoginAt   DateTime?
  dormant       Boolean  @default(false)
  privileged    Boolean  @default(false)
  createdAt     DateTime @default(now())

  ownedAssets       Asset[]       @relation("AssetOwner")
  ownedControls     Control[]     @relation("ControlOwner")
  ownedRisks        Risk[]        @relation("RiskOwner")
  assignedIncidents Incident[]    @relation("IncidentAssignee")
  approvedChanges   Change[]      @relation("ChangeApprover")
  accessReviews     AccessReview[]
}

// ============================================================
// Compliance frameworks & controls
// ============================================================

model Framework {
  id          String   @id @default(cuid())
  code        String   @unique // PRIVACY_ACT, NDB, SOCI, APRA_CPS234, ESSENTIAL8, CDR, PCI_DSS, ISO27001, SOC2, NIST_CSF
  name        String
  jurisdiction String  // AU, INTL
  regulator   String?
  description String
  mandatory   Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  controls    Control[]
}

model Control {
  id             String   @id @default(cuid())
  code           String   @unique
  title          String
  description    String
  category       String   // IAM, NETWORK, ENCRYPTION, LOGGING, BACKUP, INCIDENT, PRIVACY, SUPPLY_CHAIN
  frameworkId    String
  framework      Framework @relation(fields: [frameworkId], references: [id])
  ownerId        String?
  owner          User?    @relation("ControlOwner", fields: [ownerId], references: [id])
  status         String   // compliant, partial, non_compliant, not_applicable, exception
  maturity       Int      // 0-5
  validationFreq String   // monthly, quarterly, annual
  lastValidated  DateTime?
  nextDue        DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  evidence       Evidence[]
  exceptions     ControlException[]
  assetLinks     AssetControl[]
}

model ControlException {
  id          String   @id @default(cuid())
  controlId   String
  control     Control  @relation(fields: [controlId], references: [id])
  reason      String
  compensating String
  approver    String
  expiresAt   DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ============================================================
// Assets
// ============================================================

model Asset {
  id                  String   @id @default(cuid())
  name                String
  type                String   // server, database, saas, container, app, network, endpoint, repo
  cloudProvider       String?  // aws, azure, gcp, onprem, saas
  region              String?
  environment         String   // prod, staging, dev
  criticality         String   // critical, high, medium, low
  dataClassification  String   // public, internal, confidential, restricted
  containsPII         Boolean  @default(false)
  containsHealthData  Boolean  @default(false)
  containsCardData    Boolean  @default(false)
  encryptionAtRest    Boolean  @default(false)
  encryptionInTransit Boolean  @default(false)
  backupConfigured    Boolean  @default(false)
  backupEncrypted     Boolean  @default(false)
  retentionDays       Int?
  crossBorderTransfer Boolean  @default(false)
  publicExposure      Boolean  @default(false)
  mfaEnforced         Boolean  @default(false)
  edrInstalled        Boolean  @default(false)
  patchStatus         String   // current, lagging, critical, unknown
  lastPatchedAt       DateTime?
  soci                Boolean  @default(false) // SOCI Act in-scope
  cdr                 Boolean  @default(false) // CDR in-scope
  pci                 Boolean  @default(false)
  ownerId             String?
  owner               User?    @relation("AssetOwner", fields: [ownerId], references: [id])
  tags                String?  // JSON string
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  vulnerabilities Vulnerability[]
  incidents       IncidentAsset[]
  controlLinks    AssetControl[]
  changes         Change[]
}

model AssetControl {
  assetId    String
  controlId  String
  asset      Asset    @relation(fields: [assetId], references: [id])
  control    Control  @relation(fields: [controlId], references: [id])
  @@id([assetId, controlId])
}

// ============================================================
// Risk register
// ============================================================

model Risk {
  id              String   @id @default(cuid())
  title           String
  description     String
  category        String   // cyber, privacy, operational, supply_chain, compliance, third_party
  likelihood      Int      // 1-5
  impact          Int      // 1-5
  inherentScore   Int      // likelihood * impact
  residualScore   Int
  status          String   // open, mitigating, accepted, transferred, closed
  treatment       String   // mitigate, accept, transfer, avoid
  mitigationPlan  String?
  ownerId         String?
  owner           User?    @relation("RiskOwner", fields: [ownerId], references: [id])
  dueDate         DateTime?
  frameworkRefs   String?  // JSON array of framework codes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// Incidents (NDB Scheme + SOCI)
// ============================================================

model Incident {
  id                  String   @id @default(cuid())
  ref                 String   @unique
  title               String
  description         String
  severity            String   // critical, high, medium, low
  status              String   // open, contained, eradicated, recovered, closed
  detectionSource     String   // siem, alert, user_report, vendor, audit
  detectedAt          DateTime
  containedAt         DateTime?
  resolvedAt          DateTime?
  rootCause           String?
  ndbApplicable       Boolean  @default(false)
  ndbNotifiedOaic     Boolean  @default(false)
  ndbNotifiedUsers    Boolean  @default(false)
  ndbNotificationDate DateTime?
  sociReportable      Boolean  @default(false)
  sociReportedAt      DateTime?
  apraReportable      Boolean  @default(false)
  apraReportedAt      DateTime?
  recordsAffected     Int?
  piiAffected         Boolean  @default(false)
  assigneeId          String?
  assignee            User?    @relation("IncidentAssignee", fields: [assigneeId], references: [id])
  lessonsLearned      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  assets              IncidentAsset[]
  timeline            IncidentEvent[]
}

model IncidentAsset {
  incidentId String
  assetId    String
  incident   Incident @relation(fields: [incidentId], references: [id])
  asset      Asset    @relation(fields: [assetId], references: [id])
  @@id([incidentId, assetId])
}

model IncidentEvent {
  id          String   @id @default(cuid())
  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id])
  eventType   String   // detected, contained, escalated, notified, recovered, closed
  description String
  actor       String
  occurredAt  DateTime @default(now())
}

// ============================================================
// Vulnerabilities (Essential 8 + APRA + general)
// ============================================================

model Vulnerability {
  id            String   @id @default(cuid())
  cveId         String?
  title         String
  description   String
  severity      String   // critical, high, medium, low
  cvssScore     Float?
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  status        String   // open, in_progress, mitigated, accepted, false_positive
  exploitable   Boolean  @default(false)
  exposed       Boolean  @default(false) // internet exposed
  discoveredAt  DateTime
  slaDueAt      DateTime?
  remediatedAt  DateTime?
  remediationOwner String?
  createdAt     DateTime @default(now())
}

// ============================================================
// Evidence repository
// ============================================================

model Evidence {
  id            String   @id @default(cuid())
  title         String
  type          String   // log_export, screenshot, report, attestation, scan_result, policy_doc, test_evidence
  controlId     String?
  control       Control? @relation(fields: [controlId], references: [id])
  source        String   // aws_config, splunk, manual, audit_tool
  collectedAt   DateTime
  retentionUntil DateTime
  immutable     Boolean  @default(true)
  reference     String?  // URL or storage key
  collectedBy   String
  auditRef      String?
  createdAt     DateTime @default(now())
}

// ============================================================
// IAM & access reviews
// ============================================================

model AccessReview {
  id          String   @id @default(cuid())
  scope       String   // production, admin, vendor, prod_db, etc
  reviewerId  String
  reviewer    User     @relation(fields: [reviewerId], references: [id])
  status      String   // pending, in_progress, completed, overdue
  findings    String?
  scheduledFor DateTime
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// ============================================================
// Vendors
// ============================================================

model Vendor {
  id                String   @id @default(cuid())
  name              String
  category          String   // saas, hosting, payments, support, software
  dataAccessLevel   String   // none, internal, pii, restricted
  riskScore         Int      // 0-100
  assessmentStatus  String   // not_started, in_progress, completed, expired
  lastAssessedAt    DateTime?
  nextAssessmentDue DateTime?
  contractExpires   DateTime?
  attestations      String?  // JSON: SOC2, ISO27001, etc.
  incidents         Int      @default(0)
  active            Boolean  @default(true)
  notes             String?
  createdAt         DateTime @default(now())
}

// ============================================================
// Changes / deployment approvals
// ============================================================

model Change {
  id           String   @id @default(cuid())
  ref          String   @unique
  title        String
  description  String
  riskLevel    String   // low, medium, high, emergency
  status       String   // draft, pending_approval, approved, deployed, rolled_back, rejected
  assetId      String?
  asset        Asset?   @relation(fields: [assetId], references: [id])
  approverId   String?
  approver     User?    @relation("ChangeApprover", fields: [approverId], references: [id])
  scheduledFor DateTime?
  deployedAt   DateTime?
  rollbackAt   DateTime?
  emergency    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ============================================================
// Policies
// ============================================================

model Policy {
  id            String   @id @default(cuid())
  code          String   @unique
  title         String
  category      String   // privacy, security, retention, acceptable_use, incident, change
  version       String
  status        String   // draft, published, under_review, retired
  owner         String
  effectiveDate DateTime
  reviewDate    DateTime
  summary       String
  frameworkRefs String?  // JSON array
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// Activity / audit log
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  entity    String
  entityId  String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
}
